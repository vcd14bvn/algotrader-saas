# ─────────────────────────────────────────────────────────────────
# AlgoTrader Pro — Backend Environment Variables
# Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────────────

# MongoDB Atlas — get from cloud.mongodb.com → Connect → Drivers
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/algotrader?retryWrites=true&w=majority

# JWT secret — generate with: openssl rand -hex 32
SECRET_KEY=replace-with-64-char-random-string

# Initial admin login (email is always admin@algotrader.pro)
ADMIN_PASSWORD=change-this-strong-password

# CORS — comma-separated frontend URLs (no trailing slash)
# For Vercel: https://your-app.vercel.app
# For custom domain: https://app.yourdomain.com
ALLOWED_ORIGINS=https://your-app.vercel.app

# ─── Angel One Broker (for LIVE trading) ──────────────────────────
ANGEL_API_KEY=your_angel_one_api_key
ANGEL_CLIENT_ID=your_client_id
ANGEL_PASSWORD=your_trading_password
ANGEL_TOTP_SECRET=your_totp_secret_from_app

# ─── Telegram notifications (optional) ────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_chat_id

# ─── Optional overrides ────────────────────────────────────────────
PORT=8000
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24
