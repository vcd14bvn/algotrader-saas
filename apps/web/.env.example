# ─────────────────────────────────────────────────────────────────
# AlgoTrader Pro — Frontend Environment Variables
# For LOCAL dev: copy to .env.local
# For PRODUCTION: set these in Vercel dashboard
# ─────────────────────────────────────────────────────────────────

# Your Render backend URL (no trailing slash)
VITE_API_URL=https://your-backend.onrender.com

# WebSocket URL (same host, ws:// protocol)
VITE_WS_URL=wss://your-backend.onrender.com
